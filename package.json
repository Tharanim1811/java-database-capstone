{
  "name": "cms-ci-lint",
  "private": true,
  "scripts": {
    "lint:html": "htmlhint \"app/src/main/resources/static/**/*.html\" \"app/src/main/resources/templates/**/*.html\"",
    "lint:css": "stylelint \"app/src/main/resources/static/**/*.css\"",
    "lint:js": "eslint \"app/src/main/resources/static/**/*.js\"",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "htmlhint": "^1.1.4",
    "stylelint": "^16.14.1",
    "stylelint-config-standard": "^36.0.1"
  }
}
